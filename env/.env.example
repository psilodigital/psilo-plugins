# Psilodigital Business Agent System — example env
# Copy this to .env (gitignored) and fill in real values.
# NEVER commit real secrets. See env/secrets-policy.md.

# --- Core runtime ---
NODE_ENV=development
LOG_LEVEL=info

# --- Anthropic ---
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-opus-4-7

# --- OpenAI (Codex / fallback) ---
OPENAI_API_KEY=

# --- Google (Gemini) ---
GOOGLE_API_KEY=

# --- Productivity ---
NOTION_API_KEY=
LINEAR_API_KEY=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# --- CRM ---
HUBSPOT_API_KEY=
# or alternative CRM key

# --- Email / Calendar ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# --- Code & deploy ---
GITHUB_TOKEN=
VERCEL_TOKEN=

# --- PsiloBooking observability ---
SENTRY_DSN=
AXIOM_API_TOKEN=
AXIOM_DATASET=

# --- Payments ---
STRIPE_SECRET_KEY=
STRIPE_RESTRICTED_KEY=

# --- Database (PsiloBooking) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=  # read-only role recommended for agents

# --- Vault sync ---
VAULT_REMOTE=git@github.com:psilodigital/psilodigital-business-agent-system.git
